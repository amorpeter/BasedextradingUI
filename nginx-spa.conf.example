# =============================================================================
# REQUIRED for clean URLs: /admin/signin, /dashboard, etc.
# Without this, Nginx returns 404 for any path except /.
#
# 1. npm run build
# 2. Upload dist/* to e.g. /var/www/basedextrading (must contain index.html)
# 3. Replace this server block — do NOT use proxy_pass http://localhost:3000 for /
#    for the React app (that breaks SPA deep links).
# 4. sudo nginx -t && sudo systemctl reload nginx
# =============================================================================

server {
    server_name basedextrading.com www.basedextrading.com;

    root /var/www/basedextrading;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/basedextrading.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/basedextrading.com/privkey.pem;
}
